# ══════════════════════════════════════════════════════
#  Nika OS — Variables de Entorno
#  Copia este archivo como .env y ajusta los valores.
# ══════════════════════════════════════════════════════

# ── MQTT Broker ────────────────────────────────────────
# En desarrollo (Windows): usa 'localhost' si tienes Mosquitto local
# En producción (RPi): usa la IP de la Raspberry Pi, ej: 192.168.1.100
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# ── Servidor FastAPI ───────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Asistente de Voz ───────────────────────────────────
# Ruta al modelo Vosk. Asegúrate de que exista el directorio.
# Windows:   models/vosk-model-es-0.42
# RPi Linux: /home/pi/nikaOS/models/vosk-model-es-0.42
VOSK_MODEL_PATH=models/vosk-model-es-0.42

# Índice del dispositivo de audio (-1 = dispositivo por defecto del sistema)
# Para listar dispositivos: python -c "import pyaudio; p=pyaudio.PyAudio(); [print(i, p.get_device_info_by_index(i)['name']) for i in range(p.get_device_count())]"
AUDIO_DEVICE_INDEX=-1

# ── Sensibilidad del micrófono ─────────────────────────
# CHUNK_SIZE: Frames por chunk de audio. Menor = más responsivo, mayor uso de CPU.
#   8000 = 0.5s (lento), 4000 = 0.25s (recomendado), 2000 = 0.125s (muy rápido)
CHUNK_SIZE=4000
# COMMAND_RECORD_SECS: Segundos de grabación post-keyword
COMMAND_RECORD_SECS=5.0
# PRE_KEYWORD_CHUNKS: Chunks de audio pre-keyword a guardar (evita perder inicio de habla)
PRE_KEYWORD_CHUNKS=3

# ── TTS (espeak-ng) ────────────────────────────────────
TTS_ENABLED=true
TTS_RATE=145
TTS_VOLUME=80

# ── Nombre y configuración ─────────────────────────────
NIKA_NAME=Nika
DEBUG=false
