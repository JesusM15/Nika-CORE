# nika_client/.env.example
# Variables de entorno para el cliente Nika en laptops Windows.
# Copia como .env y ajusta los valores.

# IP de la Raspberry Pi (donde corre Mosquitto)
MQTT_BROKER=192.168.0.34
MQTT_PORT=1883

# Credenciales MQTT (vacío si no tienes autenticación)
MQTT_USER=
MQTT_PASS=

# ── Integración con Spotify (Opcional) ───────────────────────────────────────
# Obtenidos desde https://developer.spotify.com/dashboard/
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback
